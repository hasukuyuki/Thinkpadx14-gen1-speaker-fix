                {
                    L01C += One
                    P8XH (Zero, One)
                    P8XH (One, L01C)
                    SL77 ()
                }
            }
        }

        Method (_L61, 0, NotSerialized)  // _Lxx: Level-Triggered GPE, xx=0x00-0xFF
