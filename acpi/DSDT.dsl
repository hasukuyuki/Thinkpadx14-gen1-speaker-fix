    Debug = "[DSDT][AcpiTableEntry]"
    Debug = Timer
    Name (TCNB, 0x6DF2CD18)
    Name (TCNL, 0x0039)
    Name (IPNB, 0x6DF2CF18)
    Name (IPNL, 0x0001)
    Name (HGNB, 0xFFFF0000)
    Name (HGNL, 0xAA55)
    Name (IGNB, 0x6DF2CD98)
    Name (IGNL, 0x0076)
    Name (HBNB, 0x6DF2CE98)
    Name (HBNL, 0x001F)
    Name (VMNB, 0xFFFF0000)
    Name (VMNL, 0xAA55)
    Name (TSNB, 0x6DF19000)
    Name (TSNL, 0x0001)
    Scope (_SB)
    {
        Device (FSDM)
        {
            Name (ATRO, One)
            Name (ATRS, One)
            Name (ATRC, One)
            Method (SATR, 3, Serialized)
            {
                ATRO = Arg0
                ATRS = Arg1
                ATRC = Arg2
                Return (Zero)
            }

            Name (_HID, "FSDM0025")  // _HID: Hardware ID
            Name (FSOF, Zero)
            Method (_STA, 0, NotSerialized)  // _STA: Status
            {
                ATRO = ADNE /* \ADNE */
                If ((ATRO == One))
                {
                    Return (0x0F)
                }
                Else
                {
                    Return (Zero)
                }
            }

            Method (ATRR, 0, NotSerialized)
            {
                ATRS = ADME /* \ADME */
                If ((ATRS == One))
                {
                    Return (One)
                }
                Else
                {
                    Return (Zero)
                }
            }

            Method (ATRU, 0, NotSerialized)
            {
                ATRC = ADML /* \ADML */
                If ((ATRC == Zero))
                {
                    Return (One)
                }
                Else
                {
                    Return (Zero)
                }
            }

            Method (TRON, 0, NotSerialized)
            {
                Notify (FSDM, 0x80) // Status Change
                Return (Zero)
            }

            Method (TROF, 0, NotSerialized)
            {
                Notify (FSDM, 0x81) // Information Change
                Return (Zero)
            }
        }
    }

