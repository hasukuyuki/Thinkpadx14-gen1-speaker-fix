        If ((CondRefOf (FLDR) == Zero))
        {
            If ((CondRefOf (\GMIO) && CondRefOf (\_SB.PC00.RP07.PBNU)))
            {
                If ((CondRefOf (\_SB.PC00.RP07._ADR) && CondRefOf (\_SB.PC00.RP07.PXSX._ADR)))
                {
                    If (CondRefOf (WDCO))
                    {
                        OperationRegion (FLDR, SystemMemory, (GMIO (PBNU, ^_ADR (), _ADR) + WDCO), 0x06)
                        Field (FLDR, ByteAcc, NoLock, Preserve)
                        {
                            DCAP,   32, 
                            DCTR,   16
                        }
                    }
                }
            }
        }

        If ((CondRefOf (PBRR) == Zero))
        {
            If ((CondRefOf (\GMIO) && CondRefOf (\_SB.PC00.RP07.PBNU)))
            {
                If ((CondRefOf (\_SB.PC00.RP07._ADR) && CondRefOf (\_SB.PC00.RP07.PXSX._ADR)))
                {
                    OperationRegion (PBRR, SystemMemory, GMIO (PBNU, ^_ADR (), _ADR), 0x02B8)
                    Field (PBRR, AnyAcc, NoLock, Preserve)
                    {
                        Offset (0x18C), 
                        MSNL,   32, 
                        Offset (0x198), 
                        L1C1,   32, 
                        L1C2,   32, 
                        Offset (0x2B4), 
                        PTMR,   32
                    }
                }
            }
        }

        Method (WWST, 0, Serialized)
        {
            If (CondRefOf (VDID))
            {
                Switch (ToInteger (VDID))
                {
                    Case (0x100D1EAC)
                    {
                        Return (One)
                    }
                    Case (0x10071EAC)
                    {
                        Return (One)
                    }
                    Case (0x1000203E)
                    {
                        Return (One)
                    }
                    Case (0x1001203E)
                    {
                        Return (One)
                    }
                    Case (0x030817CB)
                    {
                        Return (One)
                    }
                    Case (0x4D7514C3)
                    {
                        Return (One)
                    }
                    Default
                    {
                        Return (Zero)
                    }

                }
            }
            Else
            {
                Return (Zero)
            }
        }

        Method (FHRF, 1, NotSerialized)
        {
            Name (RSTP, Package (0x02)
            {
                Zero, 
                Zero
            })
            RSTP [Zero] = WBRS /* \WBRS */
            RSTP [One] = PBRS /* \PBRS */
            If ((GGOV (\PRST) != WPRP))
            {
                DL23 ()
                SGOV (\PRST, WPRP)
            }
            Else
            {
            }

            Sleep (TR2B)
            \PINP.ON (RSTP)
            If ((Arg0 == Zero))
            {
                Sleep (TBTG)
            }
            ElseIf ((Arg0 == One))
            {
                SPCO (WCLK, Zero)
                Sleep (TB2F)
                SGOV (WFCP, (~PFCP & One))
                Sleep (TFDI)
            }
            Else
            {
            }
        }

        Method (SHRF, 0, NotSerialized)
        {
            Name (RSTP, Package (0x02)
            {
                Zero, 
                Zero
            })
            RSTP [Zero] = WBRS /* \WBRS */
            RSTP [One] = PBRS /* \PBRS */
            SPCO (WCLK, One)
            SGOV (WFCP, PFCP)
            Sleep (TN2B)
            \PINP.OFF (RSTP)
            Sleep (TB2R)
            SGOV (\PRST, (~WPRP & One))
            L23D ()
        }

        Method (DOSV, 0, NotSerialized)
        {
            If ((WSTO > Zero))
            {
                Sleep (WSTO)
            }
        }

        Method (_RST, 0, Serialized)  // _RST: Device Reset
        {
            Name (RSTP, Package (0x02)
            {
                Zero, 
                Zero
            })
            RSTP [Zero] = WBRS /* \WBRS */
            RSTP [One] = PBRS /* \PBRS */
            If ((WWEN == 0x02))
            {
                Local0 = Acquire (WWMT, 0x03E8)
                If ((Local0 == Zero))
                {
                    FHRF (Zero)
                    SHRF ()
                    Release (WWMT)
                    DOSV ()
                }
            }
            Else
            {
                \PINP.ON (RSTP)
                Sleep (0xC8)
                Notify (PXSX, One) // Device Check
                Sleep (0xC8)
                SGOV (\PRST, (~WPRP & One))
                \PINP.OFF (RSTP)
                Sleep (0xC8)
                Local0 = Zero
                While ((LASX == Zero))
                {
                    If ((Local0 > 0x14))
                    {
                        Break
                    }

                    Sleep (0x10)
                    Local0++
                }

                Sleep (0x0A)
                Notify (PXSX, One) // Device Check
            }
        }

        PowerResource (MRST, 0x05, 0x0000)
        {
            Method (_STA, 0, Serialized)  // _STA: Status
            {
                Return (One)
            }

            Method (_ON, 0, Serialized)  // _ON_: Power On
            {
            }

            Method (_OFF, 0, Serialized)  // _OFF: Power Off
            {
            }

            Method (_RST, 0, Serialized)  // _RST: Device Reset
            {
                Local0 = Acquire (WWMT, 0x03E8)
                If ((Local0 == Zero))
                {
                    FHRF (One)
                    SHRF ()
                    Release (WWMT)
                    DOSV ()
                }
            }
        }

        Method (_PRR, 0, NotSerialized)  // _PRR: Power Resource for Reset
        {
            Return (Package (0x01)
            {
                MRST
            })
        }

        Method (_DSM, 4, Serialized)  // _DSM: Device-Specific Method
        {
            If ((Arg0 == ToUUID ("bad01b75-22a8-4f48-8792-bdde9467747d") /* Unknown UUID */))
            {
                If ((Arg2 == Zero))
                {
                    Return (Buffer (One)
                    {
                         0x09                                             // .
                    })
                }

                If ((Arg2 == One)){}
                If ((Arg2 == 0x02)){}
                If ((Arg2 == 0x03))
                {
                    If ((WRTO == One)){}
                    ElseIf ((WRTO == 0x02)){}
                    ElseIf ((WRTO == 0x03)){}
                    Else
                    {
                    }

                    Return (WRTO) /* \WRTO */
                }
            }

            Return (Buffer (One)
            {
                 0x00                                             // .
            })
        }
    }

    Scope (_SB.PC00.XHCI.RHUB.HS06)
    {
        PowerResource (WWPR, 0x00, 0x0000)
        {
            Name (_STA, One)  // _STA: Status
            Method (_ON, 0, Serialized)  // _ON_: Power On
            {
                _STA = One
            }

            Method (_OFF, 0, Serialized)  // _OFF: Power Off
            {
                _STA = Zero
            }
        }

        Name (_S0W, 0x04)  // _S0W: S0 Device Wake State
        Name (_PR0, Package (0x01)  // _PR0: Power Resources for D0
        {
            WWPR
        })
        Name (_PR2, Package (0x01)  // _PR2: Power Resources for D2
        {
            WWPR
        })
        Name (_PR3, Package (0x01)  // _PR3: Power Resources for D3hot
        {
            WWPR
        })
    }

    Scope (_SB)
    {
        Device (WADN)
        {
            Name (_HID, "WWAN0001")  // _HID: Hardware ID
            Name (_CID, "WWAN0001")  // _CID: Compatible ID
            Name (_STR, Unicode ("WWAN Additional Device node"))  // _STR: Description String
            Method (_STA, 0, NotSerialized)  // _STA: Status
            {
                If ((WRDI == One))
                {
                    Return (0x0F)
                }

                Return (Zero)
            }

            Method (_DSM, 4, Serialized)  // _DSM: Device-Specific Method
            {
                Name (FUBG, Package (0x02)
                {
                    0x001A1016, 
                    Zero
                })
                If ((Arg0 == ToUUID ("a785dc2e-2732-4302-947a-397df2ae38fd") /* Unknown UUID */))
                {
                    Switch (ToInteger (Arg2))
                    {
                        Case (Zero)
                        {
                            Return (Buffer (One)
                            {
                                 0x03                                             // .
                            })
                        }
                        Case (One)
                        {
                            If ((WRDI == One))
                            {
                                SGOV (0x001A0909, Zero)
                                Sleep (0x01F4)
                                SGOV (0x001A0909, One)
                                Return (Zero)
                            }
                            Else
                            {
                                Return (0xFF)
                            }
                        }
                        Default
                        {
                            Return (0xFF)
                        }

                    }
                }
                Else
                {
                    Return (0xFF)
                }
            }
        }
    }

    Scope (\)
    {
        Name (UPC0, Package (0x04)
        {
            0xFF, 
            0x09, 
            Zero, 
            Zero
        })
        Name (PLD0, Buffer (0x10)
        {
            /* 0000 */  0x81, 0x00, 0x00, 0x00, 0x08, 0x00, 0x03, 0x00,  // ........
            /* 0008 */  0x01, 0x04, 0x80, 0x00, 0x03, 0x00, 0x00, 0x00   // ........
        })
        Name (UPC2, Package (0x04)
        {
            0xFF, 
            0x09, 
            Zero, 
            Zero
        })
        Name (PLU2, Buffer (0x10)
        {
            /* 0000 */  0x81, 0x00, 0x00, 0x00, 0x08, 0x00, 0x03, 0x00,  // ........
            /* 0008 */  0x01, 0x04, 0x00, 0x01, 0x03, 0x00, 0x00, 0x00   // ........
        })
        Name (UPCR, Package (0x04)
        {
            0xFF, 
            Zero, 
            Zero, 
            Zero
        })
        Name (PLDR, Buffer (0x10)
        {
            /* 0000 */  0x81, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  // ........
            /* 0008 */  0x59, 0x12, 0x80, 0x01, 0x03, 0x00, 0x00, 0x00   // Y.......
        })
        Name (UPCL, Package (0x04)
        {
            0xFF, 
            Zero, 
            Zero, 
            Zero
        })
        Name (PLDL, Buffer (0x10)
        {
            /* 0000 */  0x81, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  // ........
            /* 0008 */  0x51, 0x11, 0x00, 0x02, 0x03, 0x00, 0x00, 0x00   // Q.......
        })
        Name (UPR2, Package (0x04)
        {
            0xFF, 
            Zero, 
            Zero, 
            Zero
        })
        Name (PLR2, Buffer (0x10)
        {
            /* 0000 */  0x81, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  // ........
            /* 0008 */  0x59, 0x12, 0x80, 0x02, 0x03, 0x00, 0x00, 0x00   // Y.......
        })
        Name (UPCI, Package (0x04)
        {
            Zero, 
            0xFF, 
            Zero, 
            Zero
        })
        Name (PLDI, Buffer (0x10)
        {
            /* 0000 */  0x81, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  // ........
            /* 0008 */  0x30, 0x1C, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00   // 0.......
        })
        Name (PLDC, Buffer (0x14)
        {
            /* 0000 */  0x82, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  // ........
            /* 0008 */  0x24, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  // $.......
            /* 0010 */  0xDD, 0x00, 0x95, 0x00                           // ....
        })
        Method (UCPD, 2, Serialized)
        {
            Name (UPCP, Package (0x04)
            {
                Zero, 
                Zero, 
                Zero, 
                Zero
            })
            Name (PLDP, Buffer (0x10){})
            Switch (ToInteger (Arg0))
            {
                Case (One)
                {
                    If ((Arg1 == One))
                    {
                        CopyObject (UPC0, UPCP) /* \UCPD.UPCP */
                        UPCP [0x02] = E1CP /* \E1CP */
                        Return (UPCP) /* \UCPD.UPCP */
                    }
                    Else
                    {
                        PLDP = PLD0 /* \PLD0 */
                        Return (PLDP) /* \UCPD.PLDP */
                    }
                }
                Case (0x02)
                {
                    If ((Arg1 == One))
                    {
                        CopyObject (UPC2, UPCP) /* \UCPD.UPCP */
                        UPCP [0x02] = E4CP /* \E4CP */
                        Return (UPCP) /* \UCPD.UPCP */
                    }
                    Else
                    {
                        PLDP = PLU2 /* \PLU2 */
                        Return (PLDP) /* \UCPD.PLDP */
                    }
                }
                Default
                {
                    If ((Arg1 == One))
                    {
                        CopyObject (UPCI, UPCP) /* \UCPD.UPCP */
                        Return (UPCP) /* \UCPD.UPCP */
                    }
                    Else
                    {
                        PLDP = PLDI /* \PLDI */
                        Return (PLDP) /* \UCPD.PLDP */
                    }
                }

            }
        }

        Method (CCPD, 2, Serialized)
        {
            Switch (ToInteger (Arg0))
            {
                Case (Zero)
                {
                    Return (UCPD (0xFF, Arg1))
                }
                Case (One)
                {
                    Return (UCPD (One, Arg1))
                }
                Case (0x02)
                {
                    Return (UCPD (0xFF, Arg1))
                }
                Case (0x03)
                {
                    Return (UCPD (0xFF, Arg1))
                }
                Case (0x04)
                {
                    Return (UCPD (0x02, Arg1))
                }
                Default
                {
                    Return (UCPD (0xFF, Arg1))
                }

            }
        }
    }

    Scope (_SB)
    {
        Device (FAN0)
        {
            Name (_HID, EisaId ("PNP0C0B") /* Fan (Thermal Solution) */)  // _HID: Hardware ID
            Name (_UID, Zero)  // _UID: Unique ID
            Name (_STR, Unicode ("CPU fan"))  // _STR: Description String
            Name (LRPM, Zero)
            Name (URPM, 0x2710)
            Name (GRAN, 0x64)
            Name (CRPM, Zero)
            Name (TFST, Package (0x03)
            {
                Zero, 
                One, 
                0xFFFFFFFF
            })
            Method (SRPM, 1, Serialized)
            {
                CRPM = (Arg0 * GRAN) /* \_SB_.FAN0.GRAN */
            }

            Method (GRPM, 0, Serialized)
            {
                Local0 = Zero
                If (((SPSC >= 0x05) && (SPSC <= 0x06)))
                {
                    Local0 = CRPM /* \_SB_.FAN0.CRPM */
                }

                Return (Local0)
            }

            Method (_FST, 0, NotSerialized)  // _FST: Fan Status
            {
                TFST [0x02] = GRPM ()
                Return (TFST) /* \_SB_.FAN0.TFST */
            }

            Method (CRNF, 0, Serialized)
            {
                Local0 = GRPM ()
                If (((Local0 > URPM) || (Local0 < LRPM)))
                {
                    Notify (FAN0, 0x80) // Status Change
                }
            }

            Method (_DSM, 4, Serialized)  // _DSM: Device-Specific Method
            {
                If ((Arg0 == ToUUID ("a7611840-99fe-41ae-a488-35c75926c8eb") /* Fan Trip Points */))
                {
                    Switch (ToInteger (Arg2))
                    {
                        Case (Zero)
                        {
                            Return (Buffer (One)
                            {
                                 0x0F                                             // .
                            })
                        }
                        Case (One)
                        {
                            Return (GRAN) /* \_SB_.FAN0.GRAN */
                        }
                        Case (0x02)
                        {
                            LRPM = DerefOf (Arg3 [Zero])
                            URPM = DerefOf (Arg3 [One])
                            Return (Zero)
                        }
                        Case (0x03)
                        {
                            Return (Package (0x04)
                            {
                                0x03E8, 
                                0x07D0, 
                                0x19C8, 
                                0x2710
                            })
                        }
                        Default
                        {
                            Return (Buffer (One)
                            {
                                 0x00                                             // .
                            })
                        }

                    }
                }
                Else
                {
                    Return (Buffer (One)
                    {
                         0x00                                             // .
                    })
                }
            }
        }
    }

    Debug = "[DSDT][AcpiTableExit]"
    Debug = Timer
}

